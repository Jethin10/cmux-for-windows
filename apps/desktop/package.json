{
  "name": "@cmux/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Windows-first desktop command center for supervising coding-agent terminal sessions.",
  "author": "CMux for Windows contributors",
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite --host 127.0.0.1",
    "pack:win": "pnpm build && electron-builder --win --dir --config electron-builder.yml",
    "dist:win": "pnpm build && electron-builder --win nsis --config electron-builder.yml"
  },
  "dependencies": {
    "@cmux/core": "workspace:*",
    "@cmux/ipc": "workspace:*",
    "@cmux/pty": "workspace:*",
    "@cmux/shared": "workspace:*",
    "@cmux/ui": "workspace:*",
    "@vitejs/plugin-react": "^4.5.2",
    "@xterm/addon-fit": "0.10.0",
    "@xterm/xterm": "5.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "electron": "^36.4.0",
    "electron-builder": "^26.15.3"
  }
}
